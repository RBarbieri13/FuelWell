# Supabase (already used for /api/signup table inserts)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Resend — used for Founders 100 welcome email.
# If unset, signups still succeed but no email is sent (logged to console).
# Sender "max@fuelwellhealth.com" requires the fuelwellhealth.com domain
# to be verified in the Resend dashboard (adds SPF/DKIM DNS records).
# Set in production via: fly secrets set RESEND_API_KEY=re_xxx
RESEND_API_KEY=
