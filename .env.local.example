# FuelWell — local development environment variables
#
# Copy this file to `.env.local` and fill in the values below.
# `.env.local` is gitignored. Production values live in Fly.io secrets
# (`fly secrets list -a fuelwell-website`).

# --- Supabase (required) ---
# From https://supabase.com/dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-only, do NOT expose to the browser.
# Used by src/lib/supabase-admin.ts for the owner dashboard.
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (required for /founders-100 signup welcome email) ---
# From https://resend.com/api-keys
RESEND_API_KEY=

# --- Founders welcome email config (optional overrides) ---
# Defaults are baked into src/lib/email.ts; only set these to override.
FOUNDERS_EMAIL_FROM="Max Laureano <max@fuelwellhealth.com>"
FOUNDERS_EMAIL_REPLY_TO=max@fuelwellhealth.com
# Comma-separated list of CC recipients
FOUNDERS_EMAIL_CC=Max@FuelWellHealth.com,Robby@FuelWellHealth.com

# --- Owner dashboard auth ---
# Password gate for /owner (see src/proxy.ts)
ADMIN_PASSWORD=
